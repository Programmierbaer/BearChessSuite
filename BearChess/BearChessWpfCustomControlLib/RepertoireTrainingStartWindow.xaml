<Window x:Class="www.SoLaNoSoft.com.BearChessWpfCustomControlLib.RepertoireTrainingStartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:www.SoLaNoSoft.com.BearChessWpfCustomControlLib"
        xmlns:p="clr-namespace:www.SoLaNoSoft.com.BearChessWpfCustomControlLib.Properties"
        mc:Ignorable="d" WindowStartupLocation="CenterOwner" SizeToContent="Height"
        Title="{x:Static p:Resources.RepertoireTraining}" Height="350" Width="550">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid Margin="5" Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Margin="5" Grid.Column="0" Grid.Row="0" Text="Repertoire Datenbank" TextAlignment="Center"
                       VerticalAlignment="Center" />
            <ComboBox Name="comboBoxDatabases" VerticalContentAlignment="Center" HorizontalContentAlignment="Left" SelectionChanged="ComboBoxDatabases_OnSelectionChanged"
                      Margin="5" Grid.Column="1" Grid.Row="0" Width="300" HorizontalAlignment="Left" Height="25" />
            <Button Name="buttonDatabase" Margin="5" Grid.Column="2" Grid.Row="0" Background="Transparent"
                    ToolTip="Repertoire-Datenbank installieren"
                    BorderBrush="Transparent" Width="32" Height="32" Click="ButtonDatabase_OnClick">
                <Image Source="/Assets/Icons/folder_database.png" />
            </Button>
            <TextBlock Name="textBlockEmptyDatabase" HorizontalAlignment="Left" TextWrapping="Wrap" Margin="5" Foreground="Red" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" 
                       Text="Die Datenbank ist leer."/>
            
        </Grid>
        <StackPanel Margin="5,20,5,5" Grid.Row="1" Grid.Column="0">
            <CheckBox Margin="5" Name="checkBoxAllowAllMoves" VerticalAlignment="Center"
                      Content="Allow all moves" FontWeight="DemiBold" />
            <StackPanel Margin="5" Orientation="Horizontal">
                <CheckBox Name="checkBoxMakeMove" VerticalAlignment="Center" 
                          FontWeight="DemiBold" Content="{x:Static p:Resources.ExecuteMoveAutomatically}" />
                <RadioButton Name="radioButtonWhite" Margin="5" VerticalContentAlignment="Center"
                             GroupName="WhiteOrBlack" Content="{x:Static p:Resources.White}" IsChecked="True" />
                <RadioButton Name="radioButtonBlack" Margin="5" VerticalContentAlignment="Center"
                             GroupName="WhiteOrBlack" Content="{x:Static p:Resources.Black}" />
            </StackPanel>
            <StackPanel Margin="5" Orientation="Horizontal">
                <CheckBox Name="checkBoxShowNextMove" VerticalAlignment="Center"
                          Content="{x:Static p:Resources.ShowNextOpeningMove}" FontWeight="DemiBold" />
                <local:NumericUpDownUserControl Margin="5,0,0,0" TextWidthProperty="30"
                                                x:Name="numericUpDownUserControlInterval" MinValue="1"
                                                MaxValue="60" Value="3" />
                <Label VerticalAlignment="Center" Content="{x:Static p:Resources.Sec}" />
            </StackPanel>
            <CheckBox Margin="5" Name="checkBoxShowMovelist" VerticalAlignment="Center"
                      Content="Show game in move window" FontWeight="DemiBold" />
            <CheckBox Margin="5" Name="checkBoxStartGame" VerticalAlignment="Center"
                      Content="Start game" FontWeight="DemiBold" />
        </StackPanel>

        <DockPanel Margin="5" Grid.Row="2" LastChildFill="False">
            <Button Margin="5" DockPanel.Dock="Left" Name="buttonOk" Click="ButtonOk_OnClick" Background="Transparent"
                    BorderBrush="Transparent">
                <Image Source="/Assets/Icons/accept_button.png" Width="32" Height="32" />
            </Button>
            

            <Button Margin="25,5,5,5" DockPanel.Dock="Right" Click="ButtonCancel_OnClick"
                    Background="Transparent" BorderBrush="Transparent" ToolTip="{x:Static p:Resources.Exit}">
                <Image Source="/Assets/Icons/cancel.png" Width="32" Height="32" />
            </Button>
        </DockPanel>
    </Grid>
</Window>